{
  "schema_version": 1,
  "description": "VibeGuard hook registration manifest. This is the source of truth for Claude settings, Codex hooks, install hook modules, disabled_hooks exposure, and the hooks/CLAUDE.md table.",
  "profiles": ["minimal", "core", "full", "strict"],
  "hooks": [
    {
      "name": "log",
      "script": "log.sh",
      "kind": "library",
      "trigger": "Used by other hook sources",
      "responsibilities": "Log module, providing shared functions such as vg_log, JSON parsing, source code judgment, etc.",
      "decision_types": ["pass", "warn", "block", "gate", "escalate", "correction", "complete"],
      "claude": {"enabled": false, "support": "not-applicable", "reason": "shared library"},
      "codex": {"enabled": false, "support": "not-applicable", "reason": "shared library"}
    },
    {
      "name": "circuit-breaker",
      "script": "circuit-breaker.sh",
      "kind": "library",
      "trigger": "Checked by other hook sources",
      "responsibilities": "Circuit breaker library: CLOSED to OPEN to HALF-OPEN state machine, CI guard, stop_hook_active.",
      "decision_types": ["pass", "warn", "block"],
      "claude": {"enabled": false, "support": "not-applicable", "reason": "shared library"},
      "codex": {"enabled": false, "support": "not-applicable", "reason": "shared library"}
    },
    {
      "name": "run-hook-codex",
      "script": "run-hook-codex.sh",
      "kind": "wrapper",
      "trigger": "Codex wrapper",
      "responsibilities": "Codex output format adapter (decision:block to permissionDecision:deny).",
      "decision_types": [],
      "claude": {"enabled": false, "support": "not-applicable", "reason": "wrapper"},
      "codex": {"enabled": false, "support": "not-applicable", "reason": "wrapper"}
    },
    {
      "name": "pre-bash-guard",
      "script": "pre-bash-guard.sh",
      "kind": "hook",
      "install_targets": ["hooks-pre"],
      "config_exposure": {"disabled_hook": true},
      "trigger": "PreToolUse(Bash)",
      "responsibilities": "Intercept destructive local cleanup commands: dangerous rm -rf paths, git clean -f, and batch git checkout/restore .; force-push protection lives in the git pre-push hook.",
      "decision_types": ["pass", "warn", "block", "correction"],
      "claude": {
        "enabled": true,
        "event": "PreToolUse",
        "matchers": ["Bash"],
        "profiles": ["minimal", "core", "full", "strict"]
      },
      "codex": {
        "enabled": true,
        "support": "native",
        "script": "vibeguard-pre-bash-guard.sh",
        "timeout": 15,
        "entries": [
          {"event": "PreToolUse", "matcher": "Bash"},
          {"event": "PermissionRequest", "matcher": "Bash"}
        ]
      }
    },
    {
      "name": "pre-edit-guard",
      "script": "pre-edit-guard.sh",
      "kind": "hook",
      "install_targets": ["hooks-pre"],
      "config_exposure": {"disabled_hook": true},
      "trigger": "PreToolUse(Edit)",
      "responsibilities": "Block editing of non-existent files (anti-hallucination).",
      "decision_types": ["pass", "block"],
      "claude": {
        "enabled": true,
        "event": "PreToolUse",
        "matchers": ["Edit"],
        "profiles": ["minimal", "core", "full", "strict"]
      },
      "codex": {
        "enabled": true,
        "support": "native",
        "script": "vibeguard-pre-edit-guard.sh",
        "timeout": 15,
        "entries": [
          {"event": "PreToolUse", "matcher": "Edit"},
          {"event": "PermissionRequest", "matcher": "Edit"}
        ]
      }
    },
    {
      "name": "pre-write-guard",
      "script": "pre-write-guard.sh",
      "kind": "hook",
      "install_targets": ["hooks-pre"],
      "config_exposure": {"disabled_hook": true},
      "trigger": "PreToolUse(Write)",
      "responsibilities": "Remind you to search for existing implementation before creating a new source code file.",
      "decision_types": ["pass", "warn", "block", "escalate"],
      "claude": {
        "enabled": true,
        "event": "PreToolUse",
        "matchers": ["Write"],
        "profiles": ["minimal", "core", "full", "strict"]
      },
      "codex": {
        "enabled": true,
        "support": "native",
        "script": "vibeguard-pre-write-guard.sh",
        "timeout": 15,
        "entries": [
          {"event": "PreToolUse", "matcher": "Write"},
          {"event": "PermissionRequest", "matcher": "Write"}
        ]
      }
    },
    {
      "name": "post-edit-guard",
      "script": "post-edit-guard.sh",
      "kind": "hook",
      "install_targets": ["hooks-post"],
      "config_exposure": {"disabled_hook": true},
      "trigger": "PostToolUse(Edit)",
      "responsibilities": "Detect quality problems after editing: unwrap, console.log, hard-coded path, Go error discard, oversized diff, repeated editing of the same file (churn), W-15 consecutive same-file edit loop.",
      "decision_types": ["pass", "warn", "escalate", "correction"],
      "claude": {
        "enabled": true,
        "event": "PostToolUse",
        "matchers": ["Edit"],
        "profiles": ["minimal", "core", "full", "strict"]
      },
      "codex": {
        "enabled": true,
        "support": "native",
        "event": "PostToolUse",
        "matcher": "Edit",
        "script": "vibeguard-post-edit-guard.sh",
        "timeout": 15
      }
    },
    {
      "name": "post-write-guard",
      "script": "post-write-guard.sh",
      "kind": "hook",
      "install_targets": ["hooks-post"],
      "config_exposure": {"disabled_hook": true},
      "trigger": "PostToolUse(Write)",
      "responsibilities": "Detect duplicate definitions and files with the same name after creating a new file.",
      "decision_types": ["pass", "warn"],
      "claude": {
        "enabled": true,
        "event": "PostToolUse",
        "matchers": ["Write"],
        "profiles": ["minimal", "core", "full", "strict"]
      },
      "codex": {
        "enabled": true,
        "support": "native",
        "event": "PostToolUse",
        "matcher": "Write",
        "script": "vibeguard-post-write-guard.sh",
        "timeout": 15
      }
    },
    {
      "name": "analysis-paralysis-guard",
      "script": "analysis-paralysis-guard.sh",
      "kind": "hook",
      "install_targets": ["hooks-post"],
      "config_exposure": {"disabled_hook": true},
      "trigger": "PostToolUse(Read|Glob|Grep)",
      "responsibilities": "Detect excessive exploration without progress and prompt the agent to act.",
      "decision_types": ["pass", "warn"],
      "claude": {
        "enabled": true,
        "event": "PostToolUse",
        "matchers": ["Read|Glob|Grep"],
        "profiles": ["core", "full", "strict"]
      },
      "codex": {"enabled": false, "support": "unsupported", "reason": "Codex native hooks do not expose Read, Glob, or Grep tool events"}
    },
    {
      "name": "count-active-constraints",
      "script": "count_active_constraints.sh",
      "kind": "hook",
      "install_targets": [],
      "config_exposure": {"disabled_hook": true},
      "trigger": "SessionStart",
      "responsibilities": "Count effective task constraints loaded into agent context and enforce the U-32 live-context budget in strict profile.",
      "decision_types": ["pass", "warn", "block"],
      "claude": {
        "enabled": true,
        "event": "SessionStart",
        "matchers": [null],
        "profiles": ["strict"]
      },
      "codex": {"enabled": false, "support": "unsupported", "reason": "Not part of the default Codex native enforcement layer"}
    },
    {
      "name": "post-build-check",
      "script": "post-build-check.sh",
      "kind": "hook",
      "install_targets": ["hooks-full"],
      "config_exposure": {"disabled_hook": true},
      "trigger": "PostToolUse(Edit/Write)",
      "responsibilities": "Automatically run the build check corresponding to the language after editing.",
      "decision_types": ["pass", "warn", "escalate"],
      "claude": {
        "enabled": true,
        "event": "PostToolUse",
        "matchers": ["Edit", "Write"],
        "profiles": ["full", "strict"]
      },
      "codex": {
        "enabled": true,
        "support": "native",
        "script": "vibeguard-post-build-check.sh",
        "timeout": 35,
        "entries": [
          {"event": "PostToolUse", "matcher": "Bash"},
          {"event": "PostToolUse", "matcher": "Edit|Write"}
        ]
      }
    },
    {
      "name": "skills-loader",
      "script": "skills-loader.sh",
      "kind": "manual",
      "trigger": "Manual optional",
      "responsibilities": "Optional first read prompt script; not registered to hooks by default.",
      "decision_types": ["pass"],
      "claude": {"enabled": false, "support": "manual", "reason": "manual opt-in only"},
      "codex": {"enabled": false, "support": "unsupported", "reason": "not registered by default"}
    },
    {
      "name": "stop-guard",
      "script": "stop-guard.sh",
      "kind": "hook",
      "install_targets": ["hooks-full"],
      "config_exposure": {"disabled_hook": true},
      "trigger": "Stop",
      "responsibilities": "Record uncommitted source code changes as a non-blocking Stop signal.",
      "decision_types": ["pass", "gate"],
      "claude": {
        "enabled": true,
        "event": "Stop",
        "matchers": [null],
        "profiles": ["full", "strict"]
      },
      "codex": {
        "enabled": true,
        "support": "native",
        "event": "Stop",
        "matcher": null,
        "script": "vibeguard-stop-guard.sh",
        "timeout": 15
      }
    },
    {
      "name": "learn-evaluator",
      "script": "learn-evaluator.sh",
      "kind": "hook",
      "install_targets": ["hooks-full"],
      "config_exposure": {"disabled_hook": true},
      "trigger": "Stop",
      "responsibilities": "Collect metrics at the end of session, detect corrective signals, and suggest /learn when signals exist.",
      "decision_types": ["pass", "warn", "complete"],
      "claude": {
        "enabled": true,
        "event": "Stop",
        "matchers": [null],
        "profiles": ["full", "strict"]
      },
      "codex": {
        "enabled": true,
        "support": "native",
        "event": "Stop",
        "matcher": null,
        "script": "vibeguard-learn-evaluator.sh",
        "timeout": 15
      }
    },
    {
      "name": "pre-commit-guard",
      "script": "pre-commit-guard.sh",
      "kind": "git-hook",
      "install_targets": [],
      "config_exposure": {"disabled_hook": true},
      "trigger": "git pre-commit",
      "responsibilities": "Automatic guard before submission: quality check plus build check, timeout hard limit.",
      "decision_types": ["pass", "warn", "block"],
      "claude": {"enabled": false, "support": "not-applicable", "reason": "git hook"},
      "codex": {"enabled": false, "support": "not-applicable", "reason": "git hook"}
    },
    {
      "name": "git-pre-push",
      "script": "git/pre-push",
      "kind": "git-hook",
      "install_targets": [],
      "config_exposure": {"disabled_hook": false},
      "trigger": "git pre-push",
      "responsibilities": "Block non-fast-forward pushes, remote branch deletion, and force-like push options by default.",
      "decision_types": ["pass", "block"],
      "claude": {"enabled": false, "support": "not-applicable", "reason": "git hook"},
      "codex": {"enabled": false, "support": "not-applicable", "reason": "git hook"}
    }
  ]
}
