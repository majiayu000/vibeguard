{
  "hook": "hooks/git/pre-push",
  "hook_type": "git-hook",
  "input_format": "pre_push_script",
  "cases": {
    "tp/delete-branch.sh": {
      "rule": "FORCE-PUSH",
      "expect": "block",
      "description": "Interception and deletion of remote branches (local_sha=0000)"
    },
    "tp/non-fast-forward.sh": {
      "rule": "FORCE-PUSH",
      "expect": "block",
      "description": "Interception of non-fast forward push (force push)"
    },
    "fp/new-branch.sh": {
      "rule": "FORCE-PUSH",
      "expect": "pass",
      "description": "New remote branch release (remote_sha=0000)"
    },
    "fp/fast-forward.sh": {
      "rule": "FORCE-PUSH",
      "expect": "pass",
      "description": "Fast forward push release"
    }
  }
}