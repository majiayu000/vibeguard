{
  "hook": "post-write-guard.sh",
  "hook_type": "PostToolUse",
  "tool_name": "Write",
  "input_format": "mixed",
  "cases": {
    "tp/same-name-source.sh": {
      "rule": "L1",
      "expect": "warn",
      "keyword": "[L1]",
      "input_format": "script",
      "description": "Detect duplicate source files with the same name"
    },
    "tp/dup-definition.sh": {
      "rule": "L1",
      "expect": "warn",
      "keyword": "[L1]",
      "input_format": "script",
      "description": "Detect duplicate definitions"
    },
    "tp/scan-budget-exceeded.sh": {
      "rule": "L1",
      "expect": "warn",
      "keyword": "[L1]",
      "input_format": "script",
      "description": "Downgrade when file budget exceeded"
    },
    "fp/non-source-md.txt": {
      "rule": "L1",
      "expect": "pass",
      "keyword": "VIBEGUARD",
      "input_format": "write_json",
      "content": "# test",
      "description": "Non-source files (.md) are released"
    },
    "fp/no-git-project.txt": {
      "rule": "L1",
      "expect": "pass",
      "keyword": "VIBEGUARD",
      "input_format": "write_json",
      "content": "fn main() {}",
      "description": "Release when there is no git project"
    },
    "fp/empty-content.txt": {
      "rule": "L1",
      "expect": "pass",
      "keyword": "VIBEGUARD",
      "input_format": "write_json",
      "content": "",
      "description": "Empty content is allowed"
    },
    "fp/empty-filepath.txt": {
      "rule": "L1",
      "expect": "pass",
      "keyword": "VIBEGUARD",
      "input_format": "write_json",
      "file_path_override": "",
      "content": "fn main() {}",
      "description": "Empty file_path is allowed"
    },
    "fp/non-source-sh.txt": {
      "rule": "L1",
      "expect": "pass",
      "keyword": "VIBEGUARD",
      "input_format": "write_json",
      "content": "#!/bin/bash\necho test",
      "description": "Non-source extension (.sh) allowed"
    }
  }
}