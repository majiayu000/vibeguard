{
  "hook": "pre-edit-guard.sh",
  "hook_type": "PreToolUse",
  "tool_name": "Edit",
  "input_format": "raw_json",
  "cases": {
    "tp/nonexistent-file.json": {
      "rule": "BLOCK",
      "expect": "block",
      "keyword": "\"decision\": \"block\"",
      "description": "Editing non-existing files should be blocked"
    },
    "tp/path-with-quotes.json": {
      "rule": "BLOCK",
      "expect": "block",
      "keyword": "\"decision\": \"block\"",
      "description": "Paths containing single quotes are safely processed and intercepted"
    },
    "fp/existing-file.json": {
      "rule": "BLOCK",
      "expect": "pass",
      "keyword": "\"decision\": \"block\"",
      "description": "Existing file + empty old_string release"
    }
  }
}