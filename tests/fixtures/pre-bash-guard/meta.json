{
  "hook": "pre-bash-guard.sh",
  "hook_type": "PreToolUse",
  "tool_name": "Bash",
  "input_format": "command",
  "cases": {
    "tp/checkout-dot.txt": {
      "rule": "BLOCK",
      "expect": "block",
      "keyword": "\"decision\": \"block\"",
      "description": "git checkout . should be intercepted"
    },
    "tp/checkout-dot-quoted.txt": {
      "rule": "BLOCK",
      "expect": "block",
      "keyword": "\"decision\": \"block\"",
      "description": "git checkout \".\" (quoted dot) should be intercepted"
    },
    "tp/restore-dot-quoted.txt": {
      "rule": "BLOCK",
      "expect": "block",
      "keyword": "\"decision\": \"block\"",
      "description": "git restore \".\" (quoted dot) should be intercepted"
    },
    "tp/clean-fd.txt": {
      "rule": "BLOCK",
      "expect": "block",
      "keyword": "\"decision\": \"block\"",
      "description": "git clean -fd should be intercepted"
    },
    "tp/rm-rf-root.txt": {
      "rule": "BLOCK",
      "expect": "block",
      "keyword": "\"decision\": \"block\"",
      "description": "rm -rf / should be intercepted"
    },
    "tp/rm-rf-home.txt": {
      "rule": "BLOCK",
      "expect": "block",
      "keyword": "\"decision\": \"block\"",
      "description": "rm -rf ~/ should be intercepted"
    },
    "tp/rm-rf-users.txt": {
      "rule": "BLOCK",
      "expect": "block",
      "keyword": "\"decision\": \"block\"",
      "description": "rm -rf /Users/foo should be intercepted"
    },
    "fp/push-force.txt": {
      "rule": "BLOCK",
      "expect": "pass",
      "keyword": "\"decision\": \"block\"",
      "description": "git push --force is not intercepted by pre-bash-guard (moved to pre-push hook)"
    },
    "fp/push-force-lease.txt": {
      "rule": "BLOCK",
      "expect": "pass",
      "keyword": "\"decision\": \"block\"",
      "description": "git push --force-with-lease release"
    },
    "fp/reset-hard.txt": {
      "rule": "BLOCK",
      "expect": "pass",
      "keyword": "\"decision\": \"block\"",
      "description": "git reset --hard release"
    },
    "fp/rm-node-modules.txt": {
      "rule": "BLOCK",
      "expect": "pass",
      "keyword": "\"decision\": \"block\"",
      "description": "rm -rf ./node_modules release (deep subdirectory)"
    },
    "fp/npm-build.txt": {
      "rule": "BLOCK",
      "expect": "pass",
      "keyword": "\"decision\": \"block\"",
      "description": "npm run build release"
    },
    "fp/cargo-build.txt": {
      "rule": "BLOCK",
      "expect": "pass",
      "keyword": "\"decision\": \"block\"",
      "description": "cargo build --release release"
    },
    "fp/vitest-run.txt": {
      "rule": "BLOCK",
      "expect": "pass",
      "keyword": "\"decision\": \"block\"",
      "description": "vitest --run release"
    },
    "fp/commit-with-force.txt": {
      "rule": "BLOCK",
      "expect": "pass",
      "keyword": "\"decision\": \"block\"",
      "description": "commit message containing force will not cause false positives"
    },
    "fp/heredoc-force.txt": {
      "rule": "BLOCK",
      "expect": "pass",
      "keyword": "\"decision\": \"block\"",
      "description": "heredoc contains force push and no false positives"
    },
    "fp/echo-checkout-dot.txt": {
      "rule": "BLOCK",
      "expect": "pass",
      "keyword": "\"decision\": \"block\"",
      "description": "echo containing git checkout . should not be blocked"
    },
    "fp/printf-restore-dot.txt": {
      "rule": "BLOCK",
      "expect": "pass",
      "keyword": "\"decision\": \"block\"",
      "description": "printf containing git restore . should not be blocked"
    },
    "fp/commit-checkout-dot-mention.txt": {
      "rule": "BLOCK",
      "expect": "pass",
      "keyword": "\"decision\": \"block\"",
      "description": "commit message mentioning git checkout . should not be blocked"
    }
  }
}