{
  "hook": "post-build-check.sh",
  "hook_type": "PostToolUse",
  "tool_name": "Edit",
  "input_format": "build_file",
  "cases": {
    "tp/js-syntax-error.js": {
      "rule": "BUILD",
      "expect": "warn",
      "keyword": "VIBEGUARD",
      "description": "JavaScript syntax error triggers build check warning"
    },
    "fp/js-valid.js": {
      "rule": "BUILD",
      "expect": "pass",
      "keyword": "VIBEGUARD",
      "description": "JavaScript syntax is correct"
    },
    "fp/python-file.py": {
      "rule": "BUILD",
      "expect": "pass",
      "keyword": "VIBEGUARD",
      "file_path_override": "src/main.py",
      "description": "Non-build languages (.py) allowed"
    },
    "fp/markdown-file.md": {
      "rule": "BUILD",
      "expect": "pass",
      "keyword": "VIBEGUARD",
      "file_path_override": "README.md",
      "description": "Non-source files (.md) are released"
    },
    "fp/json-file.json": {
      "rule": "BUILD",
      "expect": "pass",
      "keyword": "VIBEGUARD",
      "file_path_override": "package.json",
      "description": "Non-build languages (.json) allowed"
    },
    "fp/empty-path.txt": {
      "rule": "BUILD",
      "expect": "pass",
      "keyword": "VIBEGUARD",
      "file_path_override": "",
      "description": "Empty file_path is allowed"
    }
  }
}