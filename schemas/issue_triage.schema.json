{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.local/schemas/issue_triage.schema.json",
  "title": "Issue Triage Result",
  "type": "object",
  "required": ["issue", "recommended_state", "confidence", "evidence"],
  "additionalProperties": false,
  "properties": {
    "issue": {
      "type": "integer",
      "minimum": 1
    },
    "recommended_state": {
      "enum": [
        "needs_info",
        "duplicate",
        "security_private",
        "triaged",
        "ready_to_spec",
        "ready_to_implement",
        "reserved_internal"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "evidence": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "maintainer_questions": {
      "type": "array",
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
