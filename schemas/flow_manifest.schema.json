{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.local/schemas/flow_manifest.schema.json",
  "title": "SpecRail Flow Manifest",
  "type": "object",
  "required": ["name", "version", "automation_policy", "required_human_gates"],
  "additionalProperties": true,
  "properties": {
    "name": {
      "type": "string",
      "minLength": 1
    },
    "version": {
      "type": "string",
      "minLength": 1
    },
    "automation_policy": {
      "type": "object"
    },
    "required_human_gates": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
