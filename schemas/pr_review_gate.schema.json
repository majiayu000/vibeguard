{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.local/schemas/pr_review_gate.schema.json",
  "title": "Pull Request Gate Evidence",
  "type": "object",
  "required": [
    "pr",
    "state",
    "is_draft",
    "head_sha",
    "review_completed_at",
    "gate_started_at",
    "gate_query_completed_at",
    "gate_query_head_sha",
    "linked_issue",
    "merge_state",
    "checks",
    "reviews",
    "review_threads",
    "review_source",
    "review_evidence",
    "lane_failures"
  ],
  "additionalProperties": false,
  "properties": {
    "pr": {
      "type": "integer",
      "minimum": 1
    },
    "state": {
      "type": "string",
      "minLength": 1
    },
    "is_draft": {
      "type": "boolean"
    },
    "linked_issue": {
      "type": ["integer", "null"],
      "minimum": 1
    },
    "repository": {
      "type": "string",
      "minLength": 1
    },
    "base_sha": {
      "type": "string",
      "minLength": 40
    },
    "base_ref": {
      "type": "string",
      "minLength": 1
    },
    "default_base_sha": {
      "type": "string",
      "pattern": "^[0-9a-fA-F]{40}$"
    },
    "default_base_ref": {
      "type": "string",
      "minLength": 1
    },
    "changed_files_count": {
      "type": "integer",
      "minimum": 0
    },
    "changed_files_sha256": {
      "type": "string",
      "minLength": 64
    },
    "enforcement_sensitive": {
      "type": "boolean"
    },
    "sensitive_classification": {
      "type": "object",
      "required": [
        "source",
        "changed_paths",
        "spec_refs",
        "matched_paths",
        "matched_specs",
        "registry_configured",
        "enforcement_sensitive"
      ],
      "additionalProperties": false,
      "properties": {
        "source": {
          "enum": ["github_changed_files", "tech_spec"]
        },
        "changed_paths": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "spec_refs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "matched_paths": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "matched_specs": {
          "type": "array",
          "items": {"type": "string", "minLength": 1}
        },
        "registry_configured": {"type": "boolean"},
        "enforcement_sensitive": {"type": "boolean"}
      }
    },
    "approved_spec": {
      "type": "object",
      "required": [
        "repository",
        "issue",
        "spec_paths",
        "content_hashes",
        "spec_revisions",
        "approved_at",
        "maintainer_actor",
        "state_source",
        "state_trusted",
        "default_base_ref",
        "default_base_sha"
      ],
      "additionalProperties": false,
      "properties": {
        "repository": {"type": "string", "minLength": 1},
        "issue": {"type": "integer", "minimum": 1},
        "spec_paths": {
          "type": "array",
          "minItems": 2,
          "items": {"type": "string", "minLength": 1}
        },
        "content_hashes": {"type": "object"},
        "spec_revisions": {
          "type": "object",
          "minProperties": 2,
          "additionalProperties": {
            "type": "object",
            "required": [
              "source_commit_sha",
              "pr_number",
              "merged_at",
              "merge_commit_sha"
            ],
            "additionalProperties": false,
            "properties": {
              "source_commit_sha": {
                "type": "string",
                "pattern": "^[0-9a-fA-F]{40}$"
              },
              "pr_number": {"type": "integer", "minimum": 1},
              "merged_at": {"type": "string", "minLength": 1},
              "merge_commit_sha": {
                "type": "string",
                "pattern": "^[0-9a-fA-F]{40}$"
              }
            }
          }
        },
        "approved_at": {"type": "string", "minLength": 1},
        "maintainer_actor": {"type": "string", "minLength": 1},
        "state_source": {"const": "label"},
        "state_trusted": {"const": true},
        "default_base_ref": {"type": "string", "minLength": 1},
        "default_base_sha": {
          "type": "string",
          "pattern": "^[0-9a-fA-F]{40}$"
        }
      }
    },
    "issue_reference": {
      "type": "object",
      "required": [
        "number",
        "kind",
        "source",
        "verified",
        "closing_issue_numbers"
      ],
      "additionalProperties": false,
      "properties": {
        "number": {
          "type": "integer",
          "minimum": 1
        },
        "kind": {
          "enum": ["closing", "partial"]
        },
        "source": {
          "enum": ["closingIssuesReferences", "pr_body"]
        },
        "verified": {
          "type": "boolean"
        },
        "state": {
          "type": "string",
          "minLength": 1
        },
        "url": {
          "type": "string",
          "minLength": 1
        },
        "closing_issue_numbers": {
          "type": "array",
          "items": {
            "type": "integer",
            "minimum": 1
          }
        }
      }
    },
    "head_sha": {
      "type": "string",
      "minLength": 7
    },
    "gate_query_completed_at": {
      "type": "string",
      "minLength": 1
    },
    "gate_started_at": {
      "type": "string",
      "minLength": 1
    },
    "review_completed_at": {
      "type": "string",
      "minLength": 1
    },
    "gate_query_head_sha": {
      "type": "string",
      "minLength": 7
    },
    "merge_dispatched_at": {
      "type": "string",
      "minLength": 1
    },
    "merge_head_sha": {
      "type": "string",
      "minLength": 7
    },
    "merge_state": {
      "type": "string",
      "minLength": 1
    },
    "lane_failures": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["lane_id", "failure_kind", "observed_marker"],
        "additionalProperties": true,
        "properties": {
          "lane_id": {
            "type": "string",
            "minLength": 1
          },
          "failure_kind": {
            "enum": ["usage_limit", "crash", "zero_output", "closed", "other"]
          },
          "observed_marker": {
            "type": "string",
            "minLength": 1
          },
          "pr": {"type": "integer", "minimum": 1},
          "head_sha": {"type": "string", "minLength": 7},
          "detail": {
            "type": "string"
          }
        }
      }
    },
    "checks": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "status", "conclusion"],
        "additionalProperties": true,
        "properties": {
          "name": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "type": "string",
            "minLength": 1
          },
          "conclusion": {
            "type": "string"
          }
        }
      }
    },
    "reviews": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["author", "state"],
        "additionalProperties": false,
        "properties": {
          "author": {
            "type": "string",
            "minLength": 1
          },
          "state": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    },
    "review_threads": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["is_resolved", "is_outdated", "resolved_by", "resolver_role", "original_author", "original_comment_id"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "url": {
            "type": "string"
          },
          "is_resolved": {
            "type": "boolean"
          },
          "is_outdated": {
            "type": "boolean"
          },
          "actionable": {
            "type": "boolean"
          },
          "resolved_by": {
            "type": "string",
            "minLength": 1
          },
          "original_author": {
            "type": "string",
            "minLength": 1
          },
          "original_comment_id": {
            "type": "string",
            "minLength": 1
          },
          "resolver_role": {
            "enum": ["reviewer_lane", "human", "implementer", "orchestrator", "coordinator", "unknown"]
          },
          "lane_id": {"type": "string", "minLength": 1},
          "successor_of": {"type": "string", "minLength": 1},
          "re_review_artifact_id": {"type": "string", "minLength": 1},
          "authorized_human_maintainer": {"type": "boolean"}
        }
      }
    },
    "review_evidence": {
      "type": "object",
      "required": [
        "manifest_path",
        "manifest_sha256",
        "pr",
        "head_sha",
        "review_source",
        "review_completed_at",
        "human_final_review_required",
        "lane_roster",
        "artifacts",
        "current_artifact_ids",
        "errors",
        "blocking_reasons"
      ],
      "additionalProperties": false,
      "properties": {
        "manifest_path": {"type": "string", "minLength": 1},
        "manifest_sha256": {"type": "string", "pattern": "^[0-9a-fA-F]{64}$"},
        "pr": {"type": "integer", "minimum": 1},
        "head_sha": {"type": "string", "pattern": "^[0-9a-fA-F]{40}$"},
        "review_source": {"enum": ["independent_lane", "self_review"]},
        "review_completed_at": {"type": "string", "minLength": 1},
        "human_final_review_required": {"type": "boolean"},
        "lane_roster": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "object",
            "required": ["lane_id", "producer_identity"],
            "additionalProperties": false,
            "properties": {
              "lane_id": {"type": "string", "minLength": 1},
              "producer_identity": {"type": "string", "minLength": 1},
              "successor_of": {"type": "string", "minLength": 1}
            }
          }
        },
        "artifacts": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "object", "minProperties": 1}
        },
        "current_artifact_ids": {
          "type": "array",
          "minItems": 1,
          "items": {"type": "string", "minLength": 1}
        },
        "errors": {"type": "array", "items": {"type": "string"}},
        "blocking_reasons": {"type": "array", "items": {"type": "string"}}
      }
    },
    "merge_record": {
      "type": ["object", "null"],
      "required": ["remote_confirmed"],
      "additionalProperties": true,
      "properties": {
        "merge_path": {
          "enum": ["gh_pr_merge", "api_fallback", "merged_by_other"],
          "description": "How the merge landed: gh pr merge from a neutral cwd, the gh api PUT fallback for locally checked-out branches, or merged by someone else."
        },
        "remote_confirmed": {
          "type": "boolean",
          "description": "True only after a remote query (gh pr view --json merged,mergeCommit) confirmed the outcome."
        },
        "merge_commit_sha": {
          "type": ["string", "null"]
        },
        "branch_deletion_outcome": {
          "type": ["string", "null"]
        }
      }
    },
    "review_source": {
      "enum": ["independent_lane", "self_review"],
      "description": "Source of the merge review. Only independent_lane satisfies the independent-review requirement."
    },
    "human_authorization": {
      "type": "object",
      "required": ["actor", "source"],
      "additionalProperties": true,
      "properties": {
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        }
      }
    },
    "self_review_authorization": {
      "type": "object",
      "required": ["actor", "source", "scope"],
      "additionalProperties": true,
      "properties": {
        "actor": {
          "type": "string",
          "minLength": 1
        },
        "source": {
          "type": "string",
          "minLength": 1
        },
        "scope": {
          "type": "string",
          "minLength": 1
        },
        "summary": {
          "type": "string"
        }
      }
    }
  }
}
