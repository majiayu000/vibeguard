{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.local/schemas/spec_packet.schema.json",
  "title": "Spec Packet",
  "type": "object",
  "required": ["issue", "product_spec", "tech_spec", "acceptance_criteria"],
  "additionalProperties": false,
  "properties": {
    "issue": {
      "type": "integer",
      "minimum": 1
    },
    "product_spec": {
      "type": "string",
      "pattern": "^specs/GH[0-9]+/product\\.md$"
    },
    "tech_spec": {
      "type": "string",
      "pattern": "^specs/GH[0-9]+/tech\\.md$"
    },
    "task_plan": {
      "type": ["string", "null"],
      "pattern": "^specs/GH[0-9]+/tasks\\.md$"
    },
    "acceptance_criteria": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "approved_by": {
      "type": "string"
    }
  }
}
