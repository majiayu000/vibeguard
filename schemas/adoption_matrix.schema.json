{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.local/schemas/adoption_matrix.schema.json",
  "title": "Adoption Matrix",
  "type": "object",
  "required": ["schema_version", "levels", "adoptions"],
  "additionalProperties": false,
  "properties": {
    "schema_version": {
      "type": "string",
      "minLength": 1
    },
    "levels": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    },
    "adoptions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "name", "repo", "current_level", "status", "evidence", "verified_behaviors", "next_gap"],
        "additionalProperties": true,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "name": {
            "type": "string",
            "minLength": 1
          },
          "repo": {
            "type": "string",
            "minLength": 1
          },
          "local_path_hint": {
            "type": "string",
            "minLength": 1
          },
          "current_level": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": ["active", "needs_human", "reference_only", "blocked"]
          },
          "evidence": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "object",
              "required": ["kind"],
              "additionalProperties": true,
              "properties": {
                "kind": {
                  "enum": ["specrail_artifact", "github_issue", "github_pr", "external_artifact", "external_local_path"]
                },
                "repo": {
                  "type": "string",
                  "minLength": 1
                },
                "path": {
                  "type": "string",
                  "minLength": 1
                },
                "number": {
                  "type": "integer",
                  "minimum": 1
                },
                "url": {
                  "type": "string",
                  "minLength": 1
                }
              }
            }
          },
          "verified_behaviors": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "next_gap": {
            "type": "string",
            "minLength": 1
          }
        }
      }
    }
  }
}
