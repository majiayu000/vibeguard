{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://specrail.local/schemas/task_plan.schema.json",
  "title": "Task Plan",
  "type": "object",
  "required": ["issue", "spec_packet", "tasks", "verification"],
  "additionalProperties": false,
  "properties": {
    "issue": {
      "type": "integer",
      "minimum": 1
    },
    "spec_packet": {
      "type": "string",
      "pattern": "^specs/GH[0-9]+/$"
    },
    "tasks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["id", "description", "status"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "minLength": 1
          },
          "description": {
            "type": "string",
            "minLength": 1
          },
          "status": {
            "enum": ["pending", "in_progress", "done", "blocked"]
          },
          "writable_files": {
            "type": "array",
            "items": {
              "type": "string",
              "minLength": 1
            }
          }
        }
      }
    },
    "verification": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string",
        "minLength": 1
      }
    }
  }
}
